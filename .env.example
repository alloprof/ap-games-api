# API Configuration
API_NAME='api-games'
LOG_LEVEL='info'
BUNYAN_LOGGING='false'
ENABLE_REQUEST_LOGGING='true'
PORT='8200'
BASE_PATH='/games'

# Optionnelle: By default gcloud is use but you can use service account file for Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_PATH='service-accounts/firebase.json'

# Squidex Configuration
SQUIDEX_URL='https://squidex.alloprof-staging.ca'
SQUIDEX_APPS='{"exerciseurs":{"clientId":"app:client-id","clientSecret":"your-client-secret"}}'
SQUIDEX_API_KEYS='{"grimoire-2":"your-api-key-here"}'

